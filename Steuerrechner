<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GmbH vs. Einzelunternehmen — Steuerrechner</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d0d0d;
    --bg2: #141414;
    --bg3: #1c1c1c;
    --border: rgba(255,255,255,0.06);
    --border2: rgba(255,255,255,0.12);
    --gold: #c9a84c;
    --gold2: #e8c96a;
    --text: #f0ede8;
    --text2: #8a8680;
    --text3: #4a4845;
    --green: #4caf82;
    --red: #e05c5c;
    --blue: #5c9ce0;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Background texture */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 10% 20%, rgba(201,168,76,0.04) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 90% 80%, rgba(92,156,224,0.03) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  .wrap { position: relative; z-index: 1; max-width: 900px; margin: 0 auto; padding: 0 24px; }

  /* Header */
  header {
    padding: 60px 0 48px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 48px;
  }

  .header-tag {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .header-tag::before {
    content: '';
    display: block;
    width: 24px;
    height: 1px;
    background: var(--gold);
  }

  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 700;
    line-height: 1.15;
    color: var(--text);
    margin-bottom: 12px;
  }

  h1 span { color: var(--gold); }

  .subtitle {
    font-size: 14px;
    color: var(--text2);
    line-height: 1.6;
    max-width: 520px;
  }

  .what-we-calc {
    margin-top: 28px;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 24px;
  }
  .wtc-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text3);
    margin-bottom: 16px;
  }
  .wtc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  @media (max-width: 700px) { .wtc-grid { grid-template-columns: 1fr; } }
  .wtc-heading {
    font-size: 12px;
    font-weight: 500;
    color: var(--gold);
    margin-bottom: 10px;
    font-family: 'DM Mono', monospace;
  }
  .wtc-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .wtc-list li {
    font-size: 12px;
    color: var(--text2);
    padding-left: 14px;
    position: relative;
    line-height: 1.4;
  }
  .wtc-list li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--gold);
  }


  .section-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text3);
    margin-bottom: 20px;
  }

  .input-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 32px;
  }

  @media (max-width: 600px) { .input-grid { grid-template-columns: 1fr; } }

  .field {
    background: var(--bg2);
    border: 1px solid var(--border2);
    border-radius: 8px;
    padding: 16px 18px;
    transition: border-color 0.2s;
  }
  .field:focus-within { border-color: var(--gold); }

  .field label {
    display: block;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text3);
    margin-bottom: 8px;
  }

  .field-inner {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .field input, .field select {
    background: none;
    border: none;
    outline: none;
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 18px;
    font-weight: 500;
    width: 100%;
    min-width: 0;
  }

  .field input::placeholder { color: var(--text3); }

  .field-unit {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--text3);
    white-space: nowrap;
  }

  .field select option { background: #1c1c1c; }

  /* Slider */
  .slider-field {
    grid-column: 1 / -1;
  }

  input[type="range"] {
    -webkit-appearance: none;
    width: 100%;
    height: 2px;
    background: var(--border2);
    border-radius: 2px;
    outline: none;
    margin-top: 4px;
  }
  input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--gold);
    cursor: pointer;
    box-shadow: 0 0 0 3px rgba(201,168,76,0.15);
  }

  /* Calculate Button */
  .calc-btn {
    width: 100%;
    padding: 16px;
    background: var(--gold);
    border: none;
    border-radius: 8px;
    color: #0d0d0d;
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
    margin-bottom: 48px;
  }
  .calc-btn:hover { background: var(--gold2); transform: translateY(-1px); }
  .calc-btn:active { transform: translateY(0); }

  /* Results */
  #results { display: none; }
  #results.show { display: block; animation: fadeUp 0.4s ease; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .results-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 8px;
  }

  .results-title {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-weight: 600;
  }

  .winner-badge {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    padding: 5px 12px;
    border-radius: 4px;
    letter-spacing: 0.08em;
  }
  .winner-badge.eu { background: rgba(76,175,130,0.15); color: var(--green); }
  .winner-badge.gmbh { background: rgba(92,156,224,0.15); color: var(--blue); }

  /* Comparison Cards */
  .compare-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 32px;
  }
  @media (max-width: 600px) { .compare-grid { grid-template-columns: 1fr; } }

  .card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 24px;
    position: relative;
    overflow: hidden;
  }
  .card.winner { border-color: var(--gold); }
  .card.winner::before {
    content: '★ GÜNSTIGER';
    position: absolute;
    top: 12px;
    right: 12px;
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
    color: var(--gold);
    background: rgba(201,168,76,0.1);
    padding: 3px 8px;
    border-radius: 3px;
  }

  .card-title {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text3);
    margin-bottom: 16px;
  }

  .card-total {
    font-family: 'Playfair Display', serif;
    font-size: 32px;
    font-weight: 700;
    margin-bottom: 4px;
  }
  .card-total.eu { color: var(--green); }
  .card-total.gmbh { color: var(--blue); }

  .card-subtitle {
    font-size: 12px;
    color: var(--text2);
    margin-bottom: 20px;
  }

  .tax-breakdown {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .tax-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
    font-size: 13px;
  }
  .tax-row:last-child { border-bottom: none; }

  .tax-row-label { color: var(--text2); }
  .tax-row-value {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    color: var(--text);
  }
  .tax-row-value.negative { color: var(--red); }
  .tax-row-value.highlight { color: var(--gold); font-weight: 500; }

  /* Effective rate bar */
  .rate-section {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 24px;
    margin-bottom: 24px;
  }

  .rate-title {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text3);
    margin-bottom: 20px;
  }

  .rate-bars { display: flex; flex-direction: column; gap: 16px; }

  .rate-bar-row { display: flex; flex-direction: column; gap: 6px; }

  .rate-bar-label {
    display: flex;
    justify-content: space-between;
    font-size: 13px;
  }
  .rate-bar-label span:first-child { color: var(--text2); }
  .rate-bar-label span:last-child {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
  }

  .rate-bar-track {
    height: 4px;
    background: var(--border2);
    border-radius: 4px;
    overflow: hidden;
  }

  .rate-bar-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .rate-bar-fill.eu { background: var(--green); }
  .rate-bar-fill.gmbh { background: var(--blue); }

  /* Insight Box */
  .insight {
    background: rgba(201,168,76,0.05);
    border: 1px solid rgba(201,168,76,0.15);
    border-radius: 10px;
    padding: 20px 24px;
    margin-bottom: 32px;
  }

  .insight-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 8px;
  }

  .insight p {
    font-size: 14px;
    color: var(--text2);
    line-height: 1.7;
  }

  .insight strong { color: var(--text); font-weight: 500; }

  /* Disclaimer */
  .disclaimer {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--text3);
    line-height: 1.6;
    padding-top: 32px;
    border-top: 1px solid var(--border);
    margin-bottom: 48px;
  }

  /* Footer */
  footer {
    border-top: 1px solid var(--border);
    padding: 24px 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }

  .footer-name {
    font-family: 'Playfair Display', serif;
    font-size: 15px;
    color: var(--text2);
  }
  .footer-name span { color: var(--gold); }

  .footer-tag {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--text3);
    letter-spacing: 0.1em;
  }

  /* Tooltip */
  .tooltip-wrap { position: relative; display: inline-block; }
  .tooltip-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 1px solid var(--text3);
    font-size: 9px;
    color: var(--text3);
    cursor: help;
    margin-left: 4px;
    vertical-align: middle;
  }
  .tooltip-text {
    display: none;
    position: absolute;
    bottom: 120%;
    left: 50%;
    transform: translateX(-50%);
    background: var(--bg3);
    border: 1px solid var(--border2);
    border-radius: 6px;
    padding: 8px 12px;
    font-size: 11px;
    color: var(--text2);
    width: 200px;
    line-height: 1.5;
    z-index: 10;
    pointer-events: none;
  }
  .tooltip-wrap:hover .tooltip-text { display: block; }

  .divider {
    height: 1px;
    background: var(--border);
    margin: 32px 0;
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 32px;
  }
  @media (max-width: 600px) { .info-grid { grid-template-columns: 1fr; } }

  .info-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px;
  }
  .info-card-label {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text3);
    margin-bottom: 6px;
  }
  .info-card-value {
    font-family: 'DM Mono', monospace;
    font-size: 16px;
    font-weight: 500;
    color: var(--gold);
  }
  .info-card-sub {
    font-size: 11px;
    color: var(--text3);
    margin-top: 2px;
  }
</style>
</head>
<body>
<div class="wrap">
  <header>
    <div class="header-tag">Steuerrechner · Deutschland · 2026</div>
    <h1>GmbH vs. <span>Einzelunternehmen</span><br>Steuerbelastungsvergleich</h1>
    <p class="subtitle">Vergleich der effektiven Steuerbelastung auf Basis von Körperschaftsteuer, Gewerbesteuer, Abgeltungsteuer und Einkommensteuer. Rechtsstand 2026.</p>

    <div class="what-we-calc">
      <div class="wtc-label">Was dieser Rechner berechnet</div>
      <div class="wtc-grid">
        <div class="wtc-col">
          <div class="wtc-heading">Einzelunternehmen</div>
          <ul class="wtc-list">
            <li>Gewerbesteuer inkl. Freibetrag (24.500 €)</li>
            <li>Gewerbesteuer-Anrechnung nach § 35 EStG (4× Messbetrag)</li>
            <li>Progressive Einkommensteuer 2026 (Grundtabelle)</li>
            <li>Solidaritätszuschlag auf ESt</li>
            <li>Kirchensteuer (optional, 8% oder 9%)</li>
            <li>Effektive Netto-Steuerquote</li>
          </ul>
        </div>
        <div class="wtc-col">
          <div class="wtc-heading">GmbH</div>
          <ul class="wtc-list">
            <li>Körperschaftsteuer (15%) + Solidaritätszuschlag (5,5%)</li>
            <li>Gewerbesteuer ohne Freibetrag</li>
            <li>Abgeltungsteuer (25%) auf Gewinnausschüttung</li>
            <li>SolZ auf Abgeltungsteuer</li>
            <li>Thesaurierungsstrategie (einbehaltene Gewinne)</li>
            <li>Effektive Netto-Steuerquote</li>
          </ul>
        </div>
        <div class="wtc-col">
          <div class="wtc-heading">Vergleich & Auswertung</div>
          <ul class="wtc-list">
            <li>Direktvergleich Gesamtsteuerbelastung</li>
            <li>Ersparnis mit der günstigeren Rechtsform</li>
            <li>Effektive Steuerquote als Balkendiagramm</li>
            <li>Nettobetrag der verbleibenden Mittel</li>
            <li>Steuerliche Einordnung je Gewinnklasse</li>
            <li>Hebesatz individuell einstellbar</li>
          </ul>
        </div>
      </div>
    </div>
  </header>

  <!-- Inputs -->
  <div class="section-label">Eingabe</div>
  <div class="input-grid">
    <div class="field">
      <label>Jahresgewinn (vor Steuern)</label>
      <div class="field-inner">
        <input type="number" id="gewinn" value="120000" min="0" max="10000000" step="1000" oninput="updateSlider()">
        <span class="field-unit">€</span>
      </div>
    </div>

    <div class="field">
      <label>Hebesatz Gewerbesteuer
        <span class="tooltip-wrap">
          <span class="tooltip-icon">?</span>
          <span class="tooltip-text">Durchschnitt Deutschland ca. 400%. Hamburg 470%, München 490%, Berlin 410%.</span>
        </span>
      </label>
      <div class="field-inner">
        <input type="number" id="hebesatz" value="400" min="200" max="600" step="10">
        <span class="field-unit">%</span>
      </div>
    </div>

    <div class="field slider-field">
      <label>Gewinn-Schieberegler: <span id="slider-label">120.000 €</span></label>
      <input type="range" id="gewinn-slider" min="10000" max="1000000" step="5000" value="120000" oninput="syncSlider()">
    </div>

    <div class="field">
      <label>Kirchensteuer
        <span class="tooltip-wrap">
          <span class="tooltip-icon">?</span>
          <span class="tooltip-text">Bayern & BaWü: 8%, alle anderen Bundesländer: 9% der Einkommensteuer.</span>
        </span>
      </label>
      <div class="field-inner">
        <select id="kirchensteuer">
          <option value="0">Keine</option>
          <option value="0.09">9% (Standard)</option>
          <option value="0.08">8% (Bayern/BaWü)</option>
        </select>
      </div>
    </div>

    <div class="field">
      <label>Thesaurierung GmbH
        <span class="tooltip-wrap">
          <span class="tooltip-icon">?</span>
          <span class="tooltip-text">Wie viel % des GmbH-Gewinns wird einbehalten (nicht ausgeschüttet)? Thesaurierte Gewinne unterliegen nicht der Abgeltungsteuer.</span>
        </span>
      </label>
      <div class="field-inner">
        <input type="number" id="thesaurierung" value="0" min="0" max="100" step="10">
        <span class="field-unit">%</span>
      </div>
    </div>
  </div>

  <button class="calc-btn" onclick="calculate()">Steuerbelastung berechnen →</button>

  <!-- Results -->
  <div id="results">
    <div class="results-header">
      <div class="results-title">Ergebnis</div>
      <div class="winner-badge" id="winner-badge"></div>
    </div>

    <!-- Info Cards -->
    <div class="info-grid">
      <div class="info-card">
        <div class="info-card-label">Eingabe Gewinn</div>
        <div class="info-card-value" id="info-gewinn">—</div>
        <div class="info-card-sub">vor Steuern</div>
      </div>
      <div class="info-card">
        <div class="info-card-label">Ersparnis</div>
        <div class="info-card-value" id="info-ersparnis">—</div>
        <div class="info-card-sub">mit der günstigeren Form</div>
      </div>
      <div class="info-card">
        <div class="info-card-label">Differenz</div>
        <div class="info-card-value" id="info-diff-pct">—</div>
        <div class="info-card-sub">Unterschied effektive Rate</div>
      </div>
    </div>

    <!-- Compare Cards -->
    <div class="compare-grid">
      <div class="card" id="card-eu">
        <div class="card-title">Einzelunternehmen / Personengesellschaft</div>
        <div class="card-total eu" id="eu-total">—</div>
        <div class="card-subtitle">Gesamtsteuerbelastung</div>
        <div class="tax-breakdown">
          <div class="tax-row">
            <span class="tax-row-label">Gewerbesteuer</span>
            <span class="tax-row-value negative" id="eu-gew">—</span>
          </div>
          <div class="tax-row">
            <span class="tax-row-label">GewSt-Anrechnung (§ 35 EStG)
              <span class="tooltip-wrap">
                <span class="tooltip-icon">?</span>
                <span class="tooltip-text">Die Gewerbesteuer wird pauschal mit dem 4-fachen des GewSt-Messbetrags auf die Einkommensteuer angerechnet.</span>
              </span>
            </span>
            <span class="tax-row-value" style="color:var(--green)" id="eu-anrechnung">—</span>
          </div>
          <div class="tax-row">
            <span class="tax-row-label">Einkommensteuer (inkl. SolZ)</span>
            <span class="tax-row-value negative" id="eu-est">—</span>
          </div>
          <div class="tax-row">
            <span class="tax-row-label">Kirchensteuer</span>
            <span class="tax-row-value negative" id="eu-kist">—</span>
          </div>
          <div class="tax-row" style="padding-top:12px; margin-top: 4px; border-top: 1px solid var(--border2); border-bottom: none;">
            <span class="tax-row-label" style="color:var(--text)">Netto verbleibend</span>
            <span class="tax-row-value highlight" id="eu-netto">—</span>
          </div>
        </div>
      </div>

      <div class="card" id="card-gmbh">
        <div class="card-title">GmbH (Kapitalgesellschaft)</div>
        <div class="card-total gmbh" id="gmbh-total">—</div>
        <div class="card-subtitle">Gesamtsteuerbelastung</div>
        <div class="tax-breakdown">
          <div class="tax-row">
            <span class="tax-row-label">Körperschaftsteuer (15%) + SolZ</span>
            <span class="tax-row-value negative" id="gmbh-kst">—</span>
          </div>
          <div class="tax-row">
            <span class="tax-row-label">Gewerbesteuer</span>
            <span class="tax-row-value negative" id="gmbh-gew">—</span>
          </div>
          <div class="tax-row">
            <span class="tax-row-label">Abgeltungsteuer (25%) auf Ausschüttung
              <span class="tooltip-wrap">
                <span class="tooltip-icon">?</span>
                <span class="tooltip-text">Nur auf ausgeschüttete Gewinne. Thesaurierte Gewinne bleiben in der GmbH und werden erst bei späterer Ausschüttung besteuert.</span>
              </span>
            </span>
            <span class="tax-row-value negative" id="gmbh-kest">—</span>
          </div>
          <div class="tax-row">
            <span class="tax-row-label">SolZ auf Abgeltungsteuer</span>
            <span class="tax-row-value negative" id="gmbh-solz2">—</span>
          </div>
          <div class="tax-row" style="padding-top:12px; margin-top: 4px; border-top: 1px solid var(--border2); border-bottom: none;">
            <span class="tax-row-label" style="color:var(--text)">Netto verbleibend</span>
            <span class="tax-row-value highlight" id="gmbh-netto">—</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Rate Bars -->
    <div class="rate-section">
      <div class="rate-title">Effektive Steuerquote im Vergleich</div>
      <div class="rate-bars">
        <div class="rate-bar-row">
          <div class="rate-bar-label">
            <span>Einzelunternehmen</span>
            <span id="eu-rate-label" style="color:var(--green)">—</span>
          </div>
          <div class="rate-bar-track">
            <div class="rate-bar-fill eu" id="eu-bar" style="width:0%"></div>
          </div>
        </div>
        <div class="rate-bar-row">
          <div class="rate-bar-label">
            <span>GmbH</span>
            <span id="gmbh-rate-label" style="color:var(--blue)">—</span>
          </div>
          <div class="rate-bar-track">
            <div class="rate-bar-fill gmbh" id="gmbh-bar" style="width:0%"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Insight -->
    <div class="insight">
      <div class="insight-label">⚡ Einordnung</div>
      <p id="insight-text">—</p>
    </div>

    <div class="divider"></div>

    <div class="disclaimer">
      Hinweis: Dieser Rechner dient ausschließlich zu Informationszwecken und stellt keine steuerliche Beratung dar. Die Berechnungen basieren auf vereinfachten Annahmen (kein Freibetrag, keine Sonderausgaben, keine außergewöhnlichen Belastungen, Grundtabelle). Für eine individuelle Steuerplanung wenden Sie sich an einen Steuerberater. Rechtsstand: EStG, KStG, GewStG 2026.
    </div>
  </div>

  <footer>
    <div class="footer-name">Samuel <span>Sluiter</span></div>
    <div class="footer-tag">HS Emden/Leer · 2026</div>
  </footer>
</div>

<script>
function fmt(n) {
  return new Intl.NumberFormat('de-DE', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 }).format(n);
}
function fmtPct(n) {
  return (n * 100).toFixed(1) + ' %';
}

function updateSlider() {
  const val = parseFloat(document.getElementById('gewinn').value) || 0;
  document.getElementById('gewinn-slider').value = Math.min(val, 1000000);
  document.getElementById('slider-label').textContent = fmt(val);
}

function syncSlider() {
  const val = parseFloat(document.getElementById('gewinn-slider').value);
  document.getElementById('gewinn').value = val;
  document.getElementById('slider-label').textContent = fmt(val);
}

// German income tax 2024 (simplified, Grundtabelle, no sonderfälle)
function einkommensteuer(zvE) {
  if (zvE <= 11604) return 0;
  if (zvE <= 17005) {
    const y = (zvE - 11604) / 10000;
    return Math.round((922.98 * y + 1400) * y);
  }
  if (zvE <= 66760) {
    const z = (zvE - 17005) / 10000;
    return Math.round((181.19 * z + 2397) * z + 1025.38);
  }
  if (zvE <= 277825) {
    return Math.round(0.42 * zvE - 10602.13);
  }
  return Math.round(0.45 * zvE - 18936.88);
}

function calculate() {
  const gewinn = parseFloat(document.getElementById('gewinn').value) || 0;
  const hebesatz = parseFloat(document.getElementById('hebesatz').value) / 100 || 4;
  const kirchenFaktor = parseFloat(document.getElementById('kirchensteuer').value) || 0;
  const thesaurierungPct = parseFloat(document.getElementById('thesaurierung').value) / 100 || 0;

  if (gewinn <= 0) { alert('Bitte einen Gewinn eingeben.'); return; }

  // ─── EINZELUNTERNEHMEN ───────────────────────────────────────────
  // Gewerbesteuer
  const gewStMessbetrag = Math.max(0, gewinn - 24500) * 0.035; // Freibetrag 24.500€
  const gewerbesteuer_eu = gewStMessbetrag * hebesatz;

  // § 35 EStG Anrechnung: 4 × Messbetrag, max. tatsächliche GewSt
  const anrechnungsbetrag = Math.min(gewStMessbetrag * 4, gewerbesteuer_eu);

  // Einkommensteuer auf Gewinn (ohne GewSt-Abzug, da GewSt keine BA beim EU)
  const est_brutto = einkommensteuer(gewinn);
  const est_nach_anrechnung = Math.max(0, est_brutto - anrechnungsbetrag);
  const solz_eu = est_nach_anrechnung > 18130 ? est_nach_anrechnung * 0.055 : 0;
  const est_gesamt = est_nach_anrechnung + solz_eu;
  const kist_eu = est_nach_anrechnung * kirchenFaktor;

  const total_eu = gewerbesteuer_eu + est_gesamt + kist_eu;
  const netto_eu = gewinn - total_eu;
  const rate_eu = total_eu / gewinn;

  // ─── GmbH ────────────────────────────────────────────────────────
  // Körperschaftsteuer 15% + SolZ 5,5%
  const kst = gewinn * 0.15;
  const solz_kst = kst * 0.055;
  const kst_gesamt = kst + solz_kst;

  // Gewerbesteuer GmbH (kein Freibetrag)
  const gewerbesteuer_gmbh = gewinn * 0.035 * hebesatz;

  // Gewinn nach KSt + GewSt
  const gewinn_nach_steuern = gewinn - kst_gesamt - gewerbesteuer_gmbh;
  const ausschuettung = gewinn_nach_steuern * (1 - thesaurierungPct);

  // Abgeltungsteuer 25% auf Ausschüttung + SolZ
  const kest = ausschuettung * 0.25;
  const solz_kest = kest * 0.055;
  const kest_gesamt = kest + solz_kest;

  const total_gmbh = kst_gesamt + gewerbesteuer_gmbh + kest_gesamt;
  const netto_gmbh = gewinn - total_gmbh;
  const rate_gmbh = total_gmbh / gewinn;

  // ─── Ausgabe ─────────────────────────────────────────────────────
  const eu_wins = total_eu <= total_gmbh;
  const ersparnis = Math.abs(total_eu - total_gmbh);

  // Info cards
  document.getElementById('info-gewinn').textContent = fmt(gewinn);
  document.getElementById('info-ersparnis').textContent = fmt(ersparnis);
  document.getElementById('info-diff-pct').textContent = (Math.abs(rate_eu - rate_gmbh) * 100).toFixed(1) + ' %';

  // Winner badge
  const badge = document.getElementById('winner-badge');
  badge.textContent = eu_wins ? '✓ Einzelunternehmen günstiger' : '✓ GmbH günstiger';
  badge.className = 'winner-badge ' + (eu_wins ? 'eu' : 'gmbh');

  // Cards
  document.getElementById('card-eu').className = 'card' + (eu_wins ? ' winner' : '');
  document.getElementById('card-gmbh').className = 'card' + (!eu_wins ? ' winner' : '');

  // EU values
  document.getElementById('eu-total').textContent = fmt(total_eu);
  document.getElementById('eu-gew').textContent = '− ' + fmt(gewerbesteuer_eu);
  document.getElementById('eu-anrechnung').textContent = '+ ' + fmt(anrechnungsbetrag);
  document.getElementById('eu-est').textContent = '− ' + fmt(est_gesamt);
  document.getElementById('eu-kist').textContent = kirchenFaktor > 0 ? '− ' + fmt(kist_eu) : '—';
  document.getElementById('eu-netto').textContent = fmt(netto_eu);

  // GmbH values
  document.getElementById('gmbh-total').textContent = fmt(total_gmbh);
  document.getElementById('gmbh-kst').textContent = '− ' + fmt(kst_gesamt);
  document.getElementById('gmbh-gew').textContent = '− ' + fmt(gewerbesteuer_gmbh);
  document.getElementById('gmbh-kest').textContent = '− ' + fmt(kest);
  document.getElementById('gmbh-solz2').textContent = '− ' + fmt(solz_kest);
  document.getElementById('gmbh-netto').textContent = fmt(netto_gmbh);

  // Rate bars
  const maxRate = Math.max(rate_eu, rate_gmbh);
  document.getElementById('eu-bar').style.width = (rate_eu / maxRate * 100) + '%';
  document.getElementById('gmbh-bar').style.width = (rate_gmbh / maxRate * 100) + '%';
  document.getElementById('eu-rate-label').textContent = fmtPct(rate_eu);
  document.getElementById('gmbh-rate-label').textContent = fmtPct(rate_gmbh);

  // Insight
  let insight = '';
  if (gewinn < 60000) {
    insight = `Bei einem Gewinn von <strong>${fmt(gewinn)}</strong> greift beim Einzelunternehmen noch kein Spitzensteuersatz. Die <strong>§ 35 EStG-Anrechnung</strong> der Gewerbesteuer reduziert die Einkommensteuerbelastung erheblich. Die GmbH lohnt sich in diesem Bereich meist erst bei gezielter Thesaurierungsstrategie.`;
  } else if (gewinn < 200000) {
    insight = `Im mittleren Gewinnbereich nähert sich das Einzelunternehmen dem Spitzensteuersatz (42%). Die GmbH profitiert von der <strong>flat rate Körperschaftsteuer (15% + SolZ)</strong>. Bei vollständiger Ausschüttung liegt die Gesamtbelastung der GmbH jedoch durch die <strong>Abgeltungsteuer (25%)</strong> auf Dividenden oft über dem Einzelunternehmen. Eine <strong>Thesaurierungsstrategie</strong> kann die GmbH deutlich attraktiver machen.`;
  } else {
    insight = `Ab ca. 200.000 € Gewinn greift der <strong>Spitzensteuersatz (42%) bzw. Reichensteuersatz (45%)</strong> beim Einzelunternehmen. Die GmbH mit ihrer Flat-Tax von ~30% (KSt + GewSt) bietet hier strukturelle Vorteile — insbesondere wenn Gewinne <strong>thesauriert</strong> und erst später ausgeschüttet werden. Das <strong>Teileinkünfteverfahren</strong> (§ 3 Nr. 40 EStG) als Alternative zur Abgeltungsteuer wäre bei hohen Ausschüttungen zu prüfen.`;
  }
  if (thesaurierungPct > 0) {
    insight += ` Bei <strong>${(thesaurierungPct*100).toFixed(0)}% Thesaurierung</strong> verbleiben ${fmt(gewinn_nach_steuern * thesaurierungPct)} in der GmbH — diese Gewinne unterliegen zunächst nur der KSt + GewSt und können reinvestiert werden.`;
  }
  document.getElementById('insight-text').innerHTML = insight;

  // Show
  const results = document.getElementById('results');
  results.classList.add('show');
  setTimeout(() => results.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
}

// Init slider label
document.getElementById('slider-label').textContent = fmt(120000);
</script>
</body>
</html>
